# === SOC AI Agent v10 — конфигурация ===
# Pydantic Settings читает эти переменные:
#   MCP_*       → MCPConnectionSettings
#   LLM_*       → LLMSettings
#   HTTP_*      → HTTPSettings
#   MEMORY_*    → MemorySettings
#   SEC_*       → SecuritySettings

# MCP
MCP_URL=http://127.0.0.1:3000/mcp
MCP_OWN_URL=http://127.0.0.1:8000/mcp

# LLM
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat

# HTTP
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_LOG_LEVEL=INFO

# Memory
MEMORY_ENGINE=local
MEMORY_DB_PATH=~/.soc_agent/memory.db

# Security
SEC_ACTIVE_RESPONSE_REQUIRE_2FA=true
SEC_AUDIT_LOG_ENABLED=true
